ENVIRONMENT=development
NETWORK_NAME=zoidberg-testnet
NODE_ID=node-a
NODE_HOST=127.0.0.1
NODE_PORT=8000
PUBLIC_NODE_URL=http://127.0.0.1:8000
NODE_DATA_DIR=data/node-a
STORAGE_BACKEND=json
# SQLITE_DB_PATH=data/node-a/zoidbergchain.db

# Testnet/production peer authentication should use a real secret from a secret manager.
# Never deploy testnet or production without changing PEER_SHARED_SECRET.
PEER_SHARED_SECRET=replace-with-long-random-secret
ENABLE_SIGNED_PEER_MESSAGES=true
PEER_SIGNATURE_WINDOW_SECONDS=300
PEER_REPLAY_PROTECTION_ENABLED=true

# Development mode enables local-only tools for wallet export, reset, and debugging.
# Never deploy a public server with ENVIRONMENT=development.
# Never deploy a public server with PUBLIC_API_MODE=false.
# Signed peer messages prevent sending the raw peer secret on every request.
# Development can disable signed peer messages for local testing.
# Testnet and production should enable signed peer messages.
# Testnet and production defaults block dev tools and private key export.
ALLOW_DEV_WALLET_PRIVATE_KEY_EXPORT=true
ALLOW_DEV_RESET_ENDPOINTS=true
ALLOW_INSECURE_LOCAL_PEERS=true
ENABLE_RATE_LIMITING=false
REQUIRE_PEER_AUTH=false
PUBLIC_API_MODE=false

# Rate limiting is usually disabled in local development so repeated manual testing stays smooth.
# Enable it for testnet and production to protect write-heavy and peer-facing endpoints.
RATE_LIMIT_TRANSACTION_CREATE=30/minute
RATE_LIMIT_WALLET_CREATE=30/minute
RATE_LIMIT_SUBMISSION_CREATE=20/minute
RATE_LIMIT_VOTE=60/minute
RATE_LIMIT_EVALUATE=20/minute
RATE_LIMIT_MINT=20/minute
RATE_LIMIT_CHAIN_SYNC=30/minute
RATE_LIMIT_PEER_RECEIVE=120/minute
RATE_LIMIT_PUBLIC_READ=120/minute
RATE_LIMIT_DEV_ENDPOINTS=30/minute
